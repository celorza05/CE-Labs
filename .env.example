# Copy to .env and edit as needed. The Scout runs with NO keys by default;
# everything below is optional tuning. Never commit your real .env.

# --- General ---
# SCOUT_TOP_N=25
# SCOUT_HTTP_TIMEOUT=15
# SCOUT_USER_AGENT=CE-Labs-Scout/0.1 (+https://github.com/celorza05/CE-Labs)
# SCOUT_OUTPUT_DIR=data/trends

# --- Source toggles (true/false) ---
# SCOUT_ENABLE_HACKER_NEWS=true
# SCOUT_ENABLE_REDDIT=true
# SCOUT_ENABLE_RSS=true
# SCOUT_ENABLE_GOOGLE_TRENDS=true

# --- Reddit (comma-separated subreddits) ---
# SCOUT_SUBREDDITS=LocalLLaMA,artificial,MachineLearning,OpenAI,singularity
# SCOUT_REDDIT_LIMIT=25

# --- RSS (comma-separated feed URLs) ---
# SCOUT_RSS_FEEDS=https://techcrunch.com/category/artificial-intelligence/feed/,https://arstechnica.com/ai/feed/

# --- Google Trends ---
# SCOUT_GOOGLE_TRENDS_GEO=US

# --- Ranking ---
# SCOUT_RECENCY_HALFLIFE_HOURS=36
