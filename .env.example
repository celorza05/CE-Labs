# Copy to .env and edit as needed. The Scout runs with NO keys by default;
# everything below is optional tuning. Never commit your real .env.

# --- General ---
# SCOUT_TOP_N=25
# SCOUT_HTTP_TIMEOUT=15
# SCOUT_USER_AGENT=CE-Labs-Scout/0.1 (+https://github.com/celorza05/CE-Labs)
# SCOUT_OUTPUT_DIR=data/trends

# --- Source toggles (true/false) ---
# SCOUT_ENABLE_HACKER_NEWS=true
# SCOUT_ENABLE_RSS=true
# SCOUT_ENABLE_GOOGLE_TRENDS=true
# Reddit is OFF by default (needs the OAuth credentials below). To enable:
# SCOUT_ENABLE_REDDIT=true

# --- Reddit (comma-separated subreddits) ---
# SCOUT_SUBREDDITS=LocalLLaMA,artificial,MachineLearning,OpenAI,singularity
# SCOUT_REDDIT_LIMIT=25
# Reddit blocks anonymous requests from many IPs. Create a free "script" app at
# https://www.reddit.com/prefs/apps and set these to fetch via OAuth instead:
# SCOUT_REDDIT_CLIENT_ID=your_client_id
# SCOUT_REDDIT_CLIENT_SECRET=your_client_secret

# --- RSS (comma-separated feed URLs) ---
# SCOUT_RSS_FEEDS=https://techcrunch.com/category/artificial-intelligence/feed/,https://arstechnica.com/ai/feed/

# --- Google Trends ---
# SCOUT_GOOGLE_TRENDS_GEO=US

# --- Ranking ---
# SCOUT_RECENCY_HALFLIFE_HOURS=36
# SCOUT_MAX_PER_SOURCE=6   # max items from any one feed/subreddit (0 = no cap)

# === Writer (prompt-generator) ===
# Required: Anthropic API key (separate from a Claude Pro subscription).
# Create one at https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# Optional Writer tuning:
# WRITER_MODEL=claude-opus-4-8        # or claude-sonnet-4-6 to trade quality for cost
# WRITER_SCRIPTS_PER_RUN=5            # how many scripts to produce per run
# WRITER_CANDIDATE_POOL=12            # top trends handed to the model to choose from
# WRITER_VOICE=punchy                 # punchy | neutral | hype
# WRITER_MAX_PER_COMPANY=2            # max videos about one company/product per run
# WRITER_MAX_TOKENS=16000
# WRITER_TRENDS_INPUT=data/trends/latest.json
# WRITER_OUTPUT_DIR=data/scripts

# === Producer (Higgsfield generation) ===
# Generates video via the official Higgsfield CLI:
#   npm install -g @higgsfield/cli   &&   higgsfield auth login
# Planner defaults:
# PRODUCER_ASPECT_RATIO=9:16
# PRODUCER_DURATION_SECONDS=5
# PRODUCER_SCRIPTS_INPUT=data/scripts/latest.json
# PRODUCER_OUTPUT_DIR=data/jobs
# PRODUCER_ASSETS_DIR=data/assets
# CLI submission (verify flags with `higgsfield generate create --help`, then
# confirm with `python -m src.producer --submit --dry-run` before spending):
# PRODUCER_CLI_BIN=higgsfield
# PRODUCER_HIGGSFIELD_MODEL=kling3_0     # see `higgsfield model list`
# PRODUCER_CLI_MODE=pro
# PRODUCER_CLI_SOUND=off
# PRODUCER_CLI_ASPECT_FLAG=--aspect_ratio  # Kling/most models use aspect_ratio; blank to omit
# PRODUCER_CLI_EXTRA_FLAGS=
# PRODUCER_CLI_TIMEOUT=1080

# === Publisher (YouTube upload / TikTok hand-off) ===
# Safe by default: uploads to YouTube only with --youtube, and as PRIVATE.
# YouTube needs an OAuth Desktop client from Google Cloud Console (see README).
# PUBLISHER_YOUTUBE_ENABLED=true
# PUBLISHER_YOUTUBE_CLIENT_SECRET=client_secret.json
# PUBLISHER_YOUTUBE_TOKEN_FILE=data/publish/youtube_token.json
# PUBLISHER_YOUTUBE_PRIVACY=private        # private | unlisted | public
# PUBLISHER_YOUTUBE_CATEGORY_ID=28         # 28 = Science & Technology
# PUBLISHER_TIKTOK_ENABLED=true            # prepare manual hand-off packages

# === Orchestrator (control room + Slack approval gate) ===
# Set one of these to get run summaries + approval prompts in Slack:
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...   # simplest (no scopes)
# SLACK_BOT_TOKEN=xoxb-...                                  # alternative: bot token
# SLACK_CHANNEL=#content-pipeline
# ORCHESTRATOR_GENERATE=false   # whether `prepare` also generates videos (costs credits)
# ORCHESTRATOR_STATE_DIR=data/orchestrator

# === Clips pipeline (sub-project: motivational clips) ===
# Sourcer (needs requirements-clips.txt: yt-dlp; ffmpeg on PATH):
# SOURCER_MEDIA_DIR=data/clips/media
# SOURCER_YTDLP_FORMAT=bestvideo[height<=1080]+bestaudio/best[height<=1080]/best
# SOURCER_RSS_EPISODE_INDEX=0
# Transcriber (local Whisper; needs requirements-clips.txt + ffmpeg):
# TRANSCRIBER_WHISPER_MODEL=base       # tiny|base|small|medium|large
# TRANSCRIBER_LANGUAGE=                 # e.g. en (blank = auto-detect)
# Clipper (uses ANTHROPIC_API_KEY above):
# CLIPPER_MODEL=claude-opus-4-8
# CLIPPER_CLIPS_PER_RUN=5
# CLIPPER_CLIP_MIN_SECONDS=20
# CLIPPER_CLIP_MAX_SECONDS=60
# Cutter (needs ffmpeg on PATH):
# CUTTER_FFMPEG_BIN=ffmpeg
# CUTTER_REFRAME=center            # center | face (face follows the speaker, needs opencv-python)
# CUTTER_REFRAME_SAMPLE_FPS=2.0
# CUTTER_REFRAME_JUMP_FRACTION=0.15    # face jump (fraction of frame width) that marks a speaker switch
# CUTTER_WIDTH=1080
# CUTTER_HEIGHT=1920
# CUTTER_FONT_NAME=Arial
# CUTTER_FONT_SIZE=72
# CUTTER_BG_COLOR=black
