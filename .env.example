# Copy to .env and edit as needed. The Scout runs with NO keys by default;
# everything below is optional tuning. Never commit your real .env.

# --- General ---
# SCOUT_TOP_N=25
# SCOUT_HTTP_TIMEOUT=15
# SCOUT_USER_AGENT=CE-Labs-Scout/0.1 (+https://github.com/celorza05/CE-Labs)
# SCOUT_OUTPUT_DIR=data/trends

# --- Source toggles (true/false) ---
# SCOUT_ENABLE_HACKER_NEWS=true
# SCOUT_ENABLE_RSS=true
# SCOUT_ENABLE_GOOGLE_TRENDS=true
# Reddit is OFF by default (needs the OAuth credentials below). To enable:
# SCOUT_ENABLE_REDDIT=true

# --- Reddit (comma-separated subreddits) ---
# SCOUT_SUBREDDITS=LocalLLaMA,artificial,MachineLearning,OpenAI,singularity
# SCOUT_REDDIT_LIMIT=25
# Reddit blocks anonymous requests from many IPs. Create a free "script" app at
# https://www.reddit.com/prefs/apps and set these to fetch via OAuth instead:
# SCOUT_REDDIT_CLIENT_ID=your_client_id
# SCOUT_REDDIT_CLIENT_SECRET=your_client_secret

# --- RSS (comma-separated feed URLs) ---
# SCOUT_RSS_FEEDS=https://techcrunch.com/category/artificial-intelligence/feed/,https://arstechnica.com/ai/feed/

# --- Google Trends ---
# SCOUT_GOOGLE_TRENDS_GEO=US

# --- Ranking ---
# SCOUT_RECENCY_HALFLIFE_HOURS=36
# SCOUT_MAX_PER_SOURCE=6   # max items from any one feed/subreddit (0 = no cap)

# === Writer (prompt-generator) ===
# Required: Anthropic API key (separate from a Claude Pro subscription).
# Create one at https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# Optional Writer tuning:
# WRITER_MODEL=claude-opus-4-8        # or claude-sonnet-4-6 to trade quality for cost
# WRITER_SCRIPTS_PER_RUN=5            # how many scripts to produce per run
# WRITER_CANDIDATE_POOL=12            # top trends handed to the model to choose from
# WRITER_VOICE=punchy                 # punchy | neutral | hype
# WRITER_MAX_PER_COMPANY=2            # max videos about one company/product per run
# WRITER_MAX_TOKENS=16000
# WRITER_TRENDS_INPUT=data/trends/latest.json
# WRITER_OUTPUT_DIR=data/scripts

# === Producer (Higgsfield generation) ===
# Planner is config-light; submission credentials are added once the Higgsfield
# access method is confirmed.
# PRODUCER_ASPECT_RATIO=9:16
# PRODUCER_DURATION_SECONDS=5
# PRODUCER_HIGGSFIELD_MODEL=
# PRODUCER_SCRIPTS_INPUT=data/scripts/latest.json
# PRODUCER_OUTPUT_DIR=data/jobs
